# Resend (https://resend.com) — contact form delivery.
# Free tier: 100 emails/day. Set both in Vercel project env too.
# NOTE: Resend matches the recipient case-sensitively in testing mode —
# use the EXACT lowercase address your Resend account is registered with.
RESEND_API_KEY=
CONTACT_TO_EMAIL=

# Absolute site URL for sitemap/hreflang (production domain once deployed).
NEXT_PUBLIC_SITE_URL=http://localhost:3000
